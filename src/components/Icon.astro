---
/**
 * Hand-drawn inline SVG icon set — no icon font, no emoji, no network
 * request. Every icon uses stroke=currentColor so it inherits its
 * container's color automatically.
 */
export type IconName =
  | 'search'
  | 'upload'
  | 'file'
  | 'check-circle'
  | 'swap'
  | 'keyboard'
  | 'shield';

interface Props {
  name: IconName;
}
const { name } = Astro.props;
---

{
  name === 'search' && (
    <svg class="icon" viewBox="0 0 24 24" stroke-width="1.8" stroke-linecap="round">
      <circle cx="11" cy="11" r="6.5" />
      <line x1="20" y1="20" x2="15.5" y2="15.5" />
    </svg>
  )
}
{
  name === 'upload' && (
    <svg class="icon" viewBox="0 0 24 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 16V4" />
      <path d="M7 9l5-5 5 5" />
      <path d="M4 16v3a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3" />
    </svg>
  )
}
{
  name === 'file' && (
    <svg class="icon" viewBox="0 0 24 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 3h7l4 4v13a1 1 0 0 1-1 1H7a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z" />
      <path d="M14 3v4h4" />
    </svg>
  )
}
{
  name === 'check-circle' && (
    <svg class="icon" viewBox="0 0 24 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9" />
      <path d="M8 12.5l2.5 2.5L16 9.5" />
    </svg>
  )
}
{
  name === 'swap' && (
    <svg class="icon" viewBox="0 0 24 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 4L4 7l3 3" />
      <path d="M4 7h9" />
      <path d="M17 20l3-3-3-3" />
      <path d="M20 17h-9" />
    </svg>
  )
}
{
  name === 'keyboard' && (
    <svg class="icon" viewBox="0 0 24 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="6" width="18" height="12" rx="2" />
      <path d="M6 10h.01" />
      <path d="M10 10h.01" />
      <path d="M14 10h.01" />
      <path d="M18 10h.01" />
      <path d="M6 14h8" />
    </svg>
  )
}
{
  name === 'shield' && (
    <svg class="icon" viewBox="0 0 24 24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" />
      <path d="M9 12l2 2 4-4" />
    </svg>
  )
}
