---
import Base from '../layouts/Base.astro';
import Tool from '../components/Tool.astro';
import Icon from '../components/Icon.astro';
import { getStrings } from '../i18n';

const t = getStrings('ar');
---

<Base locale="ar">
  <section class="hero">
    <h1>ابحث عن اسم داخل ملف CSV — حتى لو لم تعرف طريقة كتابته</h1>
    <p class="tagline">{t.tagline}</p>
  </section>

  <Tool locale="ar" />

  <ul class="features">
    <li>
      <span class="feature-icon"><Icon name="check-circle" /></span>
      <h3>مطابقة عربية صحيحة</h3>
      <p>
        «مُحَمَّد» و«محمّد» و«محمد» نتيجة واحدة: تجاهل التشكيل، وتوحيد الهمزات والألف
        والتاء المربوطة والأرقام الهندية.
      </p>
    </li>
    <li>
      <span class="feature-icon"><Icon name="swap" /></span>
      <h3>بحث بلا ترتيب</h3>
      <p>
        اكتب الاسم الأول واسم العائلة فقط — «صالح داهي» يجد «صالح محفوظ داهي» ولو لم
        تعرف اسم الأب.
      </p>
    </li>
    <li>
      <span class="feature-icon"><Icon name="keyboard" /></span>
      <h3>تصحيح الأخطاء الإملائية</h3>
      <p>«سالح» يجد «صالح»، وsoleh يجد saleh — قابل للتفعيل والإيقاف.</p>
    </li>
    <li>
      <span class="feature-icon"><Icon name="shield" /></span>
      <h3>ملفات ضخمة، خصوصية كاملة</h3>
      <p>
        مليون صف دون تجميد المتصفح، وملفك لا يغادر جهازك أبدًا — لا رفع، ولا خوادم، ولا
        تسجيل.
      </p>
    </li>
  </ul>

  <section class="highlights">
    <h2>لماذا FindInCSV؟</h2>
    <p class="highlights-intro">
      ثلاثة خيارات مقصودة في بناء الأداة، وليست تفصيلًا عابرًا: لا تعتمد على اتصال
      دائم، ولا تكلّفك شيئًا في نسختها الأساسية، ومبنية للعربية من الأساس لا كترجمة
      لأداة أجنبية.
    </p>
    <ul class="highlights-grid">
      <li>
        <span class="feature-icon"><Icon name="device" /></span>
        <h3>تعمل دون اتصال دائم</h3>
        <p>
          بعد تحميل الصفحة مرة واحدة، تستطيع رفع الملف والبحث فيه حتى لو انقطع
          الإنترنت — المعالجة كلها تجري داخل متصفحك، لا على خادم بعيد.
        </p>
      </li>
      <li>
        <span class="feature-icon"><Icon name="tag" /></span>
        <h3>مجانية بالكامل</h3>
        <p>بلا اشتراك، وبلا حدود مخفية، وبلا نسخة مدفوعة تحجب عنك الميزات الأساسية.</p>
      </li>
      <li>
        <span class="feature-icon"><Icon name="globe" /></span>
        <h3>عربية أولًا</h3>
        <p>
          ليست ترجمة لأداة أجنبية: التطبيع والفهرسة والواجهة مبنية لتفهم الأسماء
          العربية أولًا، والإنجليزية لغة ثانوية.
        </p>
      </li>
    </ul>
  </section>
</Base>
