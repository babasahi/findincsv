---
import Base from '../../layouts/Base.astro';
import Tool from '../../components/Tool.astro';
import Icon from '../../components/Icon.astro';
import { getStrings } from '../../i18n';

const t = getStrings('en');
---

<Base locale="en">
  <section class="hero">
    <h1>Find a name inside a CSV file — even if you don't know the exact spelling</h1>
    <p class="tagline">{t.tagline}</p>
  </section>

  <Tool locale="en" />

  <ul class="features">
    <li>
      <span class="feature-icon"><Icon name="check-circle" /></span>
      <h3>Correct Arabic matching</h3>
      <p>
        «مُحَمَّد», «محمّد» and «محمد» are one result: diacritics ignored, alef/hamza,
        ta-marbuta and Arabic-Indic digits unified.
      </p>
    </li>
    <li>
      <span class="feature-icon"><Icon name="swap" /></span>
      <h3>Order-independent search</h3>
      <p>
        Type just the first and last name — "saleh dahi" finds "Saleh Mahfoud Dahi" even
        when you don't know the father's name.
      </p>
    </li>
    <li>
      <span class="feature-icon"><Icon name="keyboard" /></span>
      <h3>Typo tolerance</h3>
      <p>"soleh" finds "saleh", "dohi" finds "dahi" — and you can switch it off.</p>
    </li>
    <li>
      <span class="feature-icon"><Icon name="shield" /></span>
      <h3>Huge files, full privacy</h3>
      <p>
        A million rows without freezing the browser, and your file never leaves your
        device — no uploads, no servers, no logging.
      </p>
    </li>
  </ul>

  <section class="highlights">
    <h2>Why FindInCSV?</h2>
    <p class="highlights-intro">
      Three deliberate choices behind how this is built, not incidental details: it
      doesn't depend on a constant connection, the core tool costs nothing, and it's
      built for Arabic from the ground up — not translated from a foreign tool.
    </p>
    <ul class="highlights-grid">
      <li>
        <span class="feature-icon"><Icon name="device" /></span>
        <h3>Works without a constant connection</h3>
        <p>
          Once the page has loaded, you can go offline and keep uploading files and
          searching — every bit of processing happens inside your browser, never on a
          remote server.
        </p>
      </li>
      <li>
        <span class="feature-icon"><Icon name="tag" /></span>
        <h3>Completely free</h3>
        <p>No subscription, no hidden row limit, no paywalled basics.</p>
      </li>
      <li>
        <span class="feature-icon"><Icon name="globe" /></span>
        <h3>Arabic-first</h3>
        <p>
          Not a translated foreign tool: the normalization, indexing, and interface
          are built around Arabic names first, with English as the secondary
          language.
        </p>
      </li>
    </ul>
  </section>
</Base>
