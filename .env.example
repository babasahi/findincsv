# Copy to .env for local development. All optional — the app runs fully
# without them (telemetry and analytics stay disabled). See SETUP.md.

# Sentry DSN (public). Without it, no Sentry code is even loaded.
PUBLIC_SENTRY_DSN=

# Plausible site domain (e.g. findincsv.com). Without it, no analytics
# script is loaded.
PUBLIC_PLAUSIBLE_DOMAIN=

# App version tag attached to Sentry events (set by CI/deploy normally).
PUBLIC_APP_VERSION=dev
